
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury item available for purchase in the Amarisé catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "collectionId": { "type": "string" },
        "basePrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isVip": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "stock": { "type": "number" },
        "listingType": { "type": "string", "enum": ["fixed", "auction"] },
        "isSubscriptionOnly": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "basePrice"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A themed set of luxury products curated by the Maison.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Affiliate": {
      "title": "Affiliate",
      "description": "A brand partner or influencer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tier": { "type": "string", "enum": ["Silver", "Gold", "Diamond"] },
        "referralCode": { "type": "string" },
        "salesGenerated": { "type": "number" },
        "commissionEarned": { "type": "number" }
      }
    },
    "ReturnRequest": {
      "title": "ReturnRequest",
      "description": "Reverse logistics tracking for an artisanal artifact.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "received", "inspecting", "refunded", "rejected"] },
        "warehouseId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Global catalog of luxury items." },
    "/collections/{collectionId}": { "schema": "Collection", "description": "Seasonal curations." },
    "/affiliates/{affiliateId}": { "schema": "Affiliate", "description": "Partner program management." },
    "/returns/{returnId}": { "schema": "ReturnRequest", "description": "Reverse logistics terminal." }
  }
}
