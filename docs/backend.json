
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury item available for purchase in the Amarisé catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "collectionId": { "type": "string" },
        "basePrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isVip": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" }
      },
      "required": ["id", "name", "category", "basePrice"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A themed set of luxury products curated by the Maison.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A record of a high-end customer purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { 
          "type": "array",
          "items": { "type": "object" }
        },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "countryCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Client critique of a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global catalog of luxury items."
    },
    "/collections/{collectionId}": {
      "schema": "Collection",
      "description": "Seasonal and Heritage collections."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global order tracking for VIP clientele."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Verified client testimonials."
    },
    "/wishlists/{userId}": {
      "schema": { "type": "object" },
      "description": "Private selection records."
    }
  }
}
