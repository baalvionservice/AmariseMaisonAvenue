
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury item available for purchase in the Amarisé catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "collectionId": { "type": "string" },
        "basePrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isVip": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "stock": { "type": "number" },
        "listingType": { "type": "string", "enum": ["fixed", "auction"] },
        "isSubscriptionOnly": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "basePrice"]
    },
    "SearchIndexEntry": {
      "title": "SearchIndexEntry",
      "description": "A vectorized entry for semantic search discovery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "latentFeatures": { "type": "array", "items": { "type": "number" }, "description": "Mock embedding vector." },
        "country": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "A financial transaction record within the Maison settlement layer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "gateway": { "type": "string", "enum": ["STRIPE", "RAZORPAY", "PAYU", "BANK_TRANSFER"] },
        "gatewayPaymentId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "SUCCESS", "FAILED", "REFUNDED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "amount", "currency", "gateway"]
    },
    "PaymentLog": {
      "title": "PaymentLog",
      "description": "Historical audit trace for a specific payment event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "paymentId": { "type": "string" },
        "action": { "type": "string", "enum": ["INIT", "SUCCESS", "FAILURE", "REFUND", "RECONCILIATION"] },
        "metadata": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Global catalog of luxury items." },
    "/search_index/{entryId}": { "schema": "SearchIndexEntry", "description": "Vectorized registry for semantic discovery." },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Treasury settlement records." },
    "/payments/{paymentId}/logs/{logId}": { "schema": "PaymentLog", "description": "Detailed transaction traces." }
  }
}
