
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury item available for purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "collectionId": { "type": "string" },
        "basePrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isVip": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" }
      },
      "required": ["id", "name", "category", "basePrice"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A themed set of luxury products.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global catalog of luxury items."
    },
    "/collections/{collectionId}": {
      "schema": "Collection",
      "description": "Curated seasonal and heritage collections."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history."
    }
  }
}
