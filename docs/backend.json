
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury item available for purchase in the Amarisé catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "collectionId": { "type": "string" },
        "basePrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isVip": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" }
      },
      "required": ["id", "name", "category", "basePrice"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A themed set of luxury products curated by the Maison.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A global marketing initiative targeting specific regions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["email", "push", "social"] },
        "status": { "type": "string", "enum": ["draft", "scheduled", "active", "completed"] },
        "reach": { "type": "number" },
        "engagement": { "type": "number" },
        "country": { "type": "string" }
      }
    },
    "Affiliate": {
      "title": "Affiliate",
      "description": "A luxury brand partner or influencer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tier": { "type": "string", "enum": ["silver", "gold", "diamond"] },
        "salesGenerated": { "type": "number" },
        "commissionPaid": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A record of a high-end customer purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { 
          "type": "array",
          "items": { "type": "object" }
        },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "countryCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Global catalog of luxury items." },
    "/collections/{collectionId}": { "schema": "Collection", "description": "Seasonal and Heritage collections." },
    "/campaigns/{campaignId}": { "schema": "Campaign", "description": "Global marketing campaigns." },
    "/affiliates/{affiliateId}": { "schema": "Affiliate", "description": "Brand partner management." },
    "/orders/{orderId}": { "schema": "Order", "description": "Global order tracking." },
    "/reviews/{reviewId}": { "schema": { "$ref": "#/entities/Review" }, "description": "Client testimonials." }
  }
}
